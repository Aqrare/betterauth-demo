# Docker Compose プロジェクト名
# git worktreeで複数環境を運用する場合は、各ディレクトリで異なる名前を設定してください
COMPOSE_PROJECT_NAME=auth-demo-main

# ポート番号設定
# 複数環境を同時に起動する場合は、各ディレクトリで異なるポート番号を設定してください

# Postgres
POSTGRES_PORT=5433

# Backend
BACKEND_PORT=3000

# Frontend
FRONTEND_PORT=5173

# Resource MS
RESOURCE_MS_PORT=4001

# OPA
OPA_PORT=8181

# URLs
BETTER_AUTH_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
